<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Cover Letter</title>
  <style>
    body {
      font-family: sans-serif;
      font-size: 12pt;
      line-height: 1.5;
      color: #000;
      max-width: 800px;
      margin: 0 auto;
    }
    .header {
      margin-bottom: 20px;
    }
    .header p {
      margin: 2px 0;
    }
    .header p:first-child {
      font-weight: 700;
      font-size: 18pt;
    }
    .location,
    .email,
    .phone, 
    .loc-phn {
      display: flex;
      gap: 10px;
      align-items: center;
      font-size: 18pt;
      font-weight: normal;
    }
    .company {
      margin-top: 30px;
      margin-bottom: 20px;
    }
    .body p {
      margin-bottom: 16px;
      text-align: justify;
    }
    .closing {
      margin-top: 30px;
    }
    .closing p {
      margin: 0;
    }
    .corner1 {
      height: 35px;
      background-color: #f8f8f8;
    }
     .corner2 {
      height: 35px;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background-color: #f8f8f8;
      width: 100%;
    }
    .container{
      position: relative;
    }
    .breaker {
      height: 3px;
      border: none;
      background-color: #f6f6f6;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="corner1"></div>
   <div style="margin: 60px;">
     <!-- User Info -->
    <div class="header">
      <p><%= fullname %></p>
        <p><%= postalcode %>, <%= city %> (<%= country %>)</p>
        <p><%= email %>&nbsp;&nbsp;|&nbsp;&nbsp;<%= phone %></p>
      </div>
    <hr class="breaker">

    <!-- Company -->
    <div class="company">
      <p>Dear <%= companyName %>,</p>
    </div>

    <!-- Body Paragraphs -->
    <div class="body">
      <% if (paragraphs && paragraphs.length) { %>
        <% paragraphs.forEach(function(p) { %>
          <p><%= p %></p>
        <% }); %>
      <% } %>
    </div>

    <!-- Closing -->
    <div class="closing">
      <p>Yours sincerely,<br><%= fullname %></p>
    </div>
   </div>
    <div class="corner2"></div>

  </div>
</body>
</html>